pipeline {
    agent any

    environment {
        CI = 'true'
    }

    stages {

        // ----------------------
        // 1️⃣ Build Stage
        // ----------------------
        stage('Build') {
            steps {
                echo 'Installing npm dependencies...'
                sh 'npm install'
            }
        }

        // ----------------------
        // 2️⃣ Test Stage
        // ----------------------
        stage('Test') {
            steps {
                echo 'Running unit tests...'
                sh './jenkins/scripts/test.sh'
            }
        }

        // ----------------------
        // 3️⃣ SonarQube Analysis
        // ----------------------
        stage('SonarQube Analysis') {
            steps {
                echo 'Running SonarQube analysis...'
                withSonarQubeEnv('sonarqube') {   // Jenkins SonarQube server name
                    script {
                        // Use the Jenkins-installed SonarScanner
                        def scannerHome = tool name: 'sonarscanner', type: 'hudson.plugins.sonar.SonarRunnerInstallation'
                        sh "${scannerHome}/bin/sonar-scanner -Dsonar.projectKey=week12-project -Dsonar.sources=./src"
                    }
                }
            }
        }

        // ----------------------
        // 4️⃣ Quality Gate
        // ----------------------
        stage('Quality Gate') {
            steps {
                echo 'Checking SonarQube Quality Gate status...'
                timeout(time: 5, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        // ----------------------
        // 5️⃣ Deliver Stage
        // ----------------------
        stage('Deliver') {
            steps {
                echo 'Deploying application...'
                sh './jenkins/scripts/deliver.sh'
                input message: 'Finished using the web site? (Click "Proceed" to continue)'
                sh './jenkins/scripts/kill.sh'
            }
        }
    }

    // ----------------------
    // Post actions
    // ----------------------
    post {
        success {
            echo 'Pipeline completed successfully ✅'
        }
        failure {
            echo 'Pipeline failed ❌'
        }
    }
}
